-- 临时关闭外键约束检查（防止删除表时因依赖关系报错）
SET FOREIGN_KEY_CHECKS = 0;

-- 创建数据库
CREATE DATABASE IF NOT EXISTS `internship_report`
    DEFAULT CHARACTER SET utf8mb4
    COLLATE utf8mb4_unicode_ci;

USE `internship_report`;

-- =============================================
-- 一、基础表 
-- =============================================

-- 1. 用户表
DROP TABLE IF EXISTS `users`;
CREATE TABLE `users` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '用户ID',
    `username` VARCHAR(50) NOT NULL COMMENT '用户名',
    `password` VARCHAR(255) NOT NULL COMMENT '密码(加密)',
    `real_name` VARCHAR(50) NOT NULL COMMENT '真实姓名',
    `email` VARCHAR(100) DEFAULT NULL COMMENT '邮箱',
    `phone` VARCHAR(20) DEFAULT NULL COMMENT '电话',
    `role` VARCHAR(20) NOT NULL COMMENT '角色: STUDENT-学生, TEACHER-导师, ADMIN-管理员',
    `student_no` VARCHAR(50) DEFAULT NULL COMMENT '学号(学生)',
    `department` VARCHAR(50) DEFAULT NULL COMMENT '院系',
    `major` VARCHAR(50) DEFAULT NULL COMMENT '专业',
    `class_name` VARCHAR(20) DEFAULT NULL COMMENT '班级',
    `avatar` VARCHAR(255) DEFAULT NULL COMMENT '头像URL',
    `status` VARCHAR(20) DEFAULT 'ACTIVE' COMMENT '状态: ACTIVE-正常, INACTIVE-禁用, GRADUATED-已毕业',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    `update_time` DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    PRIMARY KEY (`id`),
    UNIQUE KEY `uk_username` (`username`),
    KEY `idx_role` (`role`),
    KEY `idx_status` (`status`),
    KEY `idx_student_no` (`student_no`),
    KEY `idx_department` (`department`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='用户表';

-- 2. 企业表 
DROP TABLE IF EXISTS `companies`;
CREATE TABLE `companies` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '企业ID',
    `name` VARCHAR(100) NOT NULL COMMENT '企业名称',
    `industry` VARCHAR(50) DEFAULT NULL COMMENT '所属行业',
    `address` VARCHAR(200) DEFAULT NULL COMMENT '详细地址',
    `city` VARCHAR(20) DEFAULT NULL COMMENT '所在城市',
    `province` VARCHAR(20) DEFAULT NULL COMMENT '所在省份',
    `contact_name` VARCHAR(50) DEFAULT NULL COMMENT '联系人',
    `contact_phone` VARCHAR(20) DEFAULT NULL COMMENT '联系电话',
    `contact_email` VARCHAR(100) DEFAULT NULL COMMENT '联系邮箱',
    `description` VARCHAR(500) DEFAULT NULL COMMENT '企业描述',
    `logo_url` VARCHAR(255) DEFAULT NULL COMMENT '企业Logo',
    `website` VARCHAR(100) DEFAULT NULL COMMENT '企业官网',
    `status` VARCHAR(20) NOT NULL DEFAULT 'ACTIVE' COMMENT '状态: ACTIVE-正常, INACTIVE-暂停, BLACKLISTED-黑名单',
    `student_count` INT NOT NULL DEFAULT 0 COMMENT '实习学生数',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    `update_time` DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    PRIMARY KEY (`id`),
    UNIQUE KEY `uk_name` (`name`),
    KEY `idx_status` (`status`),
    KEY `idx_city` (`city`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='企业表';

-- 3. 实习信息表
DROP TABLE IF EXISTS `internships`;
CREATE TABLE `internships` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '实习ID',
    `student_id` BIGINT NOT NULL COMMENT '学生ID',
    `teacher_id` BIGINT DEFAULT NULL COMMENT '指导老师ID',
    `company_id` BIGINT DEFAULT NULL COMMENT '企业ID(v2.0新增)',
    `company` VARCHAR(100) NOT NULL COMMENT '实习单位',
    `company_name` VARCHAR(100) DEFAULT NULL COMMENT '企业名称冗余(v2.0新增)',
    `position` VARCHAR(100) DEFAULT NULL COMMENT '实习岗位',
    `address` VARCHAR(200) DEFAULT NULL COMMENT '实习地址',
    `company_contact` VARCHAR(200) DEFAULT NULL COMMENT '企业联系人',
    `company_phone` VARCHAR(20) DEFAULT NULL COMMENT '企业联系电话',
    `start_date` DATE NOT NULL COMMENT '开始日期',
    `end_date` DATE NOT NULL COMMENT '结束日期',
    `status` VARCHAR(20) NOT NULL DEFAULT 'ONGOING' COMMENT '状态: DRAFT-草稿, PENDING-待审核, ONGOING-进行中, COMPLETED-已完成, REJECTED-已驳回',
    `description` VARCHAR(500) DEFAULT NULL COMMENT '实习描述',
    `teacher_comment` VARCHAR(500) DEFAULT NULL COMMENT '导师评语',
    `work_content` TEXT DEFAULT NULL COMMENT '工作内容',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    `update_time` DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    PRIMARY KEY (`id`),
    KEY `idx_student_id` (`student_id`),
    KEY `idx_teacher_id` (`teacher_id`),
    KEY `idx_status` (`status`),
    KEY `idx_company_id` (`company_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='实习信息表';

-- 4. 汇报表
DROP TABLE IF EXISTS `reports`;
CREATE TABLE `reports` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '汇报ID',
    `internship_id` BIGINT NOT NULL COMMENT '实习ID',
    `student_id` BIGINT NOT NULL COMMENT '学生ID',
    `title` VARCHAR(100) NOT NULL COMMENT '汇报标题',
    `report_type` VARCHAR(20) NOT NULL COMMENT '汇报类型: WEEKLY-周报, MONTHLY-月报, FINAL-总结报告',
    `content` TEXT DEFAULT NULL COMMENT '汇报内容',
    `summary` TEXT DEFAULT NULL COMMENT '工作总结',
    `problem` TEXT DEFAULT NULL COMMENT '遇到的问题',
    `solution` TEXT DEFAULT NULL COMMENT '解决方案',
    `plan` TEXT DEFAULT NULL COMMENT '下周计划',
    `report_date` DATE DEFAULT NULL COMMENT '汇报日期',
    `week_number` INT DEFAULT NULL COMMENT '第几周',
    `status` VARCHAR(20) NOT NULL DEFAULT 'DRAFT' COMMENT '状态: DRAFT-草稿, SUBMITTED-已提交, REVIEWED-已批阅, RETURNED-已退回',
    `reviewer_id` BIGINT DEFAULT NULL COMMENT '批阅人ID',
    `review_comment` TEXT DEFAULT NULL COMMENT '批阅意见',
    `score` INT DEFAULT NULL COMMENT '评分(0-100)',
    `review_time` DATETIME DEFAULT NULL COMMENT '批阅时间',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    `update_time` DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    PRIMARY KEY (`id`),
    KEY `idx_internship_id` (`internship_id`),
    KEY `idx_student_id` (`student_id`),
    KEY `idx_reviewer_id` (`reviewer_id`),
    KEY `idx_report_type` (`report_type`),
    KEY `idx_status` (`status`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='汇报表';

-- 5. 附件表
DROP TABLE IF EXISTS `attachments`;
CREATE TABLE `attachments` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '附件ID',
    `report_id` BIGINT DEFAULT NULL COMMENT '汇报ID',
    `internship_id` BIGINT DEFAULT NULL COMMENT '实习ID',
    `uploader_id` BIGINT NOT NULL COMMENT '上传者ID',
    `file_name` VARCHAR(200) NOT NULL COMMENT '原始文件名',
    `stored_name` VARCHAR(200) NOT NULL COMMENT '存储文件名',
    `file_path` VARCHAR(500) NOT NULL COMMENT '文件路径',
    `file_size` BIGINT NOT NULL COMMENT '文件大小(字节)',
    `file_type` VARCHAR(50) DEFAULT NULL COMMENT '文件类型',
    `attachment_type` VARCHAR(20) NOT NULL DEFAULT 'OTHER' COMMENT '附件类型: REPORT-汇报附件, INTERNSHIP-实习证明, CERTIFICATE-证书, OTHER-其他',
    `upload_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '上传时间',
    PRIMARY KEY (`id`),
    KEY `idx_report_id` (`report_id`),
    KEY `idx_internship_id` (`internship_id`),
    KEY `idx_uploader_id` (`uploader_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='附件表';

-- 6. 位置记录表
DROP TABLE IF EXISTS `location_records`;
CREATE TABLE `location_records` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '记录ID',
    `student_id` BIGINT NOT NULL COMMENT '学生ID',
    `internship_id` BIGINT DEFAULT NULL COMMENT '实习ID',
    `longitude` DECIMAL(10, 6) NOT NULL COMMENT '经度',
    `latitude` DECIMAL(10, 6) NOT NULL COMMENT '纬度',
    `address` VARCHAR(200) DEFAULT NULL COMMENT '地址',
    `city` VARCHAR(50) DEFAULT NULL COMMENT '城市',
    `province` VARCHAR(50) DEFAULT NULL COMMENT '省份',
    `record_type` VARCHAR(20) DEFAULT 'AUTO' COMMENT '记录类型: CHECK_IN-上班打卡, CHECK_OUT-下班打卡, AUTO-自动, MANUAL-手动',
    `remark` VARCHAR(500) DEFAULT NULL COMMENT '备注',
    `record_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '记录时间',
    PRIMARY KEY (`id`),
    KEY `idx_student_id` (`student_id`),
    KEY `idx_internship_id` (`internship_id`),
    KEY `idx_city` (`city`),
    KEY `idx_record_time` (`record_time`),
    KEY `idx_record_type` (`record_type`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='位置记录表';

-- 7. 通知表 
DROP TABLE IF EXISTS `notifications`;
CREATE TABLE `notifications` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '通知ID',
    `recipient_id` BIGINT NOT NULL COMMENT '接收者ID',
    `title` VARCHAR(200) NOT NULL COMMENT '通知标题',
    `content` VARCHAR(1000) NOT NULL COMMENT '通知内容',
    `type` VARCHAR(30) NOT NULL COMMENT '通知类型: SYSTEM-系统, INTERNSHIP-实习, REPORT-汇报, CHECKIN-签到',
    `related_type` VARCHAR(50) DEFAULT NULL COMMENT '关联类型',
    `related_id` BIGINT DEFAULT NULL COMMENT '关联ID',
    `is_read` BOOLEAN NOT NULL DEFAULT FALSE COMMENT '是否已读',
    `created_at` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    PRIMARY KEY (`id`),
    KEY `idx_recipient` (`recipient_id`),
    KEY `idx_unread` (`recipient_id`, `is_read`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='通知表';

-- 8. 评价表 
DROP TABLE IF EXISTS `evaluations`;
CREATE TABLE `evaluations` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '评价ID',
    `internship_id` BIGINT NOT NULL COMMENT '实习ID',
    `student_id` BIGINT NOT NULL COMMENT '学生ID',
    `evaluator_id` BIGINT NOT NULL COMMENT '评价人ID',
    `evaluator_type` VARCHAR(50) DEFAULT NULL COMMENT '评价人类型',
    `work_performance` INT NOT NULL COMMENT '工作表现(1-5)',
    `learning_ability` INT NOT NULL COMMENT '学习能力(1-5)',
    `communication` INT NOT NULL COMMENT '沟通能力(1-5)',
    `punctuality` INT NOT NULL COMMENT '准时性(1-5)',
    `overall` INT NOT NULL COMMENT '综合评分(1-5)',
    `strengths` VARCHAR(1000) DEFAULT NULL COMMENT '优点',
    `weaknesses` VARCHAR(1000) DEFAULT NULL COMMENT '不足',
    `suggestions` VARCHAR(1000) DEFAULT NULL COMMENT '建议',
    `created_at` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    PRIMARY KEY (`id`),
    KEY `idx_student` (`student_id`),
    KEY `idx_internship` (`internship_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='评价表';

-- 9. 导出记录表 
DROP TABLE IF EXISTS `export_records`;
CREATE TABLE `export_records` (
    `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '导出ID',
    `user_id` BIGINT NOT NULL COMMENT '用户ID',
    `export_type` VARCHAR(50) NOT NULL COMMENT '导出类型: CHECKIN-签到, REPORT-汇报, STUDENT-学生',
    `file_name` VARCHAR(255) NOT NULL COMMENT '文件名',
    `created_at` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    PRIMARY KEY (`id`),
    KEY `idx_user_id` (`user_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='导出记录表';

-- =============================================
-- 二、添加外键约束 (此时才开启检查)
-- =============================================

-- internships 外键
ALTER TABLE `internships`
    ADD CONSTRAINT `fk_internship_student` FOREIGN KEY (`student_id`) REFERENCES `users` (`id`) ON DELETE RESTRICT,
    ADD CONSTRAINT `fk_internship_teacher` FOREIGN KEY (`teacher_id`) REFERENCES `users` (`id`) ON DELETE SET NULL,
    ADD CONSTRAINT `fk_internship_company` FOREIGN KEY (`company_id`) REFERENCES `companies` (`id`) ON DELETE SET NULL;

-- reports 外键
ALTER TABLE `reports`
    ADD CONSTRAINT `fk_report_internship` FOREIGN KEY (`internship_id`) REFERENCES `internships` (`id`) ON DELETE CASCADE,
    ADD CONSTRAINT `fk_report_student` FOREIGN KEY (`student_id`) REFERENCES `users` (`id`) ON DELETE RESTRICT,
    ADD CONSTRAINT `fk_report_reviewer` FOREIGN KEY (`reviewer_id`) REFERENCES `users` (`id`) ON DELETE SET NULL;

-- attachments 外键
ALTER TABLE `attachments`
    ADD CONSTRAINT `fk_attachment_report` FOREIGN KEY (`report_id`) REFERENCES `reports` (`id`) ON DELETE CASCADE,
    ADD CONSTRAINT `fk_attachment_internship` FOREIGN KEY (`internship_id`) REFERENCES `internships` (`id`) ON DELETE CASCADE,
    ADD CONSTRAINT `fk_attachment_uploader` FOREIGN KEY (`uploader_id`) REFERENCES `users` (`id`) ON DELETE RESTRICT;

-- location_records 外键
ALTER TABLE `location_records`
    ADD CONSTRAINT `fk_location_student` FOREIGN KEY (`student_id`) REFERENCES `users` (`id`) ON DELETE CASCADE,
    ADD CONSTRAINT `fk_location_internship` FOREIGN KEY (`internship_id`) REFERENCES `internships` (`id`) ON DELETE SET NULL;

-- notifications 外键
ALTER TABLE `notifications`
    ADD CONSTRAINT `fk_notification_recipient` FOREIGN KEY (`recipient_id`) REFERENCES `users` (`id`) ON DELETE CASCADE;

-- evaluations 外键
ALTER TABLE `evaluations`
    ADD CONSTRAINT `fk_evaluation_internship` FOREIGN KEY (`internship_id`) REFERENCES `internships` (`id`) ON DELETE CASCADE,
    ADD CONSTRAINT `fk_evaluation_student` FOREIGN KEY (`student_id`) REFERENCES `users` (`id`) ON DELETE CASCADE,
    ADD CONSTRAINT `fk_evaluation_evaluator` FOREIGN KEY (`evaluator_id`) REFERENCES `users` (`id`) ON DELETE CASCADE;

